# URL base del sito - usato per costruire i link nelle email (recupero password,
# in futuro altre notifiche). In produzione: https://ramirezatelier.it (un solo
# dominio, v. ADR-0005 §4).
SITE_URL="http://localhost:3000"

# Database (PostgreSQL) - Prisma 7: DATABASE_URL è usata dall'app a runtime (via
# driver adapter in src/server/db.ts), DIRECT_URL dal CLI Prisma per le migrazioni
# (configurata in prisma.config.ts). In locale possono coincidere; su Supabase
# DATABASE_URL è la stringa con pooler (porta 6543), DIRECT_URL quella diretta/
# sessione (porta 5432).
DATABASE_URL="postgresql://ramirez:ramirez_dev_password@localhost:5432/ramirez_atelier?schema=public"
DIRECT_URL="postgresql://ramirez:ramirez_dev_password@localhost:5432/ramirez_atelier?schema=public"

# Object Storage S3-compatible (MinIO in locale, Supabase Storage in
# staging/produzione - decisione presa, v. DEPLOY-RUNBOOK.md Fase 0)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="ramirez_minio"
S3_SECRET_KEY="ramirez_minio_secret"
S3_BUCKET="richieste-progetto"
